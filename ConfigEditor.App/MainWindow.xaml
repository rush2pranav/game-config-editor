<Window x:Class="ConfigEditor.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ConfigEditor.App.ViewModels"
        xmlns:conv="clr-namespace:ConfigEditor.App.Converters"
        Title="Game Config Editor — gRPC + Entity Framework" 
        Height="800" Width="1300" MinHeight="650" MinWidth="1050"
        WindowStartupLocation="CenterScreen" Background="#1A1A2E">

    <Window.DataContext>
        <vm:EditorViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <SolidColorBrush x:Key="Bg1" Color="#1A1A2E"/>
        <SolidColorBrush x:Key="Bg2" Color="#16213E"/>
        <SolidColorBrush x:Key="Bg3" Color="#0F3460"/>
        <SolidColorBrush x:Key="Accent" Color="#E94560"/>
        <SolidColorBrush x:Key="Text1" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="Text2" Color="#8892A0"/>
        <SolidColorBrush x:Key="Border" Color="#2A2A4A"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:SafeIntConverter x:Key="SafeInt"/>
        <conv:SafeDoubleConverter x:Key="SafeDouble"/>

        <!-- tab item stle section -->
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#8892A0"/>
            <Setter Property="Background" Value="#16213E"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder" Background="#16213E" Padding="14,8" Margin="2,0" CornerRadius="6,6,0,0"
                                BorderBrush="#2A2A4A" BorderThickness="1,1,1,0">
                            <ContentPresenter ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#0F3460"/>
                                <Setter Property="Foreground" Value="#E0E0E0"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#1E3A5F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- list view item style section -->
        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="ItemBorder" Background="{TemplateBinding Background}" 
                                Padding="{TemplateBinding Padding}" BorderThickness="0">
                            <GridViewRowPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#1E3A5F"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#0F3460"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EditorLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Text2}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <Style x:Key="EditorInput" TargetType="TextBox">
            <Setter Property="Background" Value="#0D1B2A"/>
            <Setter Property="Foreground" Value="{StaticResource Text1}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="{StaticResource Text1}"/>
        </Style>

        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="Z" Modifiers="Ctrl" Command="{Binding UndoCommand}"/>
        <KeyBinding Key="Y" Modifiers="Ctrl" Command="{Binding RedoCommand}"/>
        <KeyBinding Key="Z" Modifiers="Ctrl+Shift" Command="{Binding RedoCommand}"/>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- toolbar section -->
        <Border Grid.Row="0" Background="{StaticResource Bg2}" Padding="12,8"
                BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBlock Text="⚔️" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Game Config Editor" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource Text1}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <Button Content="💾 Save (Ctrl+S)" Command="{Binding SaveCommand}"
                            Style="{StaticResource ActionBtn}" Background="#0F3460" Margin="0,0,4,0"/>
                    <Button Content="↩ Undo" Command="{Binding UndoCommand}" ToolTip="{Binding UndoTooltip}"
                            Style="{StaticResource ActionBtn}" Background="#2A2A4A" Margin="0,0,4,0"/>
                    <Button Content="↪ Redo" Command="{Binding RedoCommand}" ToolTip="{Binding RedoTooltip}"
                            Style="{StaticResource ActionBtn}" Background="#2A2A4A" Margin="0,0,4,0"/>
                    <Button Content="🔄 Refresh" Command="{Binding RefreshCommand}"
                            Style="{StaticResource ActionBtn}" Background="#2A2A4A" Margin="0,0,4,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="+ New Weapon" Command="{Binding NewWeaponCommand}"
                            Style="{StaticResource ActionBtn}" Background="#E94560" Margin="0,0,4,0"/>
                    <Button Content="+ New Enemy" Command="{Binding NewEnemyCommand}"
                            Style="{StaticResource ActionBtn}" Background="#E94560" Margin="0,0,4,0"/>
                    <Button Content="+ New Item" Command="{Binding NewItemCommand}"
                            Style="{StaticResource ActionBtn}" Background="#E94560" Margin="0,0,4,0"/>
                    <Button Content="🗑 Delete" Command="{Binding DeleteCommand}"
                            Style="{StaticResource ActionBtn}" Background="#8B0000"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- main content section -->
        <TabControl Grid.Row="1" SelectedIndex="{Binding SelectedTab}" Background="{StaticResource Bg1}"
                    BorderThickness="0" Margin="8">

            <!-- weapons tab section -->
            <TabItem Header="⚔️ Weapons" Foreground="{StaticResource Text1}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="350"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- weapon list section -->
                    <Border Background="{StaticResource Bg2}" CornerRadius="6" Margin="4">
                        <ListView ItemsSource="{Binding Weapons}" SelectedItem="{Binding SelectedWeapon}"
                                  Background="Transparent" BorderThickness="0" Foreground="{StaticResource Text1}">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Name" Width="140">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Name}" Foreground="#E0E0E0" FontSize="12"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Cat" Width="65">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Category}" Foreground="#8892A0" FontSize="11"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="DMG" Width="45">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Damage}" Foreground="#E94560" FontSize="11"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Rarity" Width="70">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Rarity}" Foreground="#FFD700" FontSize="11"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Border>

                    <!-- weapon editor section -->
                    <Border Grid.Column="1" Background="{StaticResource Bg2}" CornerRadius="6" Margin="4" Padding="16">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" Style="{StaticResource EditorLabel}"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding WName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorInput}"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Category" Style="{StaticResource EditorLabel}"/>
                                <ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding Categories}" SelectedItem="{Binding WCategory}" FontSize="12"/>
                                <TextBlock Grid.Row="2" Grid.Column="2" Text="Rarity" Style="{StaticResource EditorLabel}"/>
                                <ComboBox Grid.Row="2" Grid.Column="3" ItemsSource="{Binding Rarities}" SelectedItem="{Binding WRarity}" FontSize="12"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Damage" Style="{StaticResource EditorLabel}"/>
                                <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding WDamage, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource SafeInt}}" Style="{StaticResource EditorInput}"/>
                                <TextBlock Grid.Row="4" Grid.Column="2" Text="Fire Rate" Style="{StaticResource EditorLabel}"/>
                                <TextBox Grid.Row="4" Grid.Column="3" Text="{Binding WFireRate, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource SafeDouble}}" Style="{StaticResource EditorInput}"/>

                                <TextBlock Grid.Row="6" Grid.Column="0" Text="Magazine" Style="{StaticResource EditorLabel}"/>
                                <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding WMagSize, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource SafeInt}}" Style="{StaticResource EditorInput}"/>
                                <TextBlock Grid.Row="6" Grid.Column="2" Text="Reload Time" Style="{StaticResource EditorLabel}"/>
                                <TextBox Grid.Row="6" Grid.Column="3" Text="{Binding WReloadTime, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource SafeDouble}}" Style="{StaticResource EditorInput}"/>

                                <TextBlock Grid.Row="8" Grid.Column="0" Text="Accuracy" Style="{StaticResource EditorLabel}"/>
                                <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding WAccuracy, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource SafeDouble}}" Style="{StaticResource EditorInput}"/>
                                <TextBlock Grid.Row="8" Grid.Column="2" Text="Range" Style="{StaticResource EditorLabel}"/>
                                <TextBox Grid.Row="8" Grid.Column="3" Text="{Binding WRange, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource SafeDouble}}" Style="{StaticResource EditorInput}"/>

                                <TextBlock Grid.Row="10" Grid.Column="0" Text="Cost" Style="{StaticResource EditorLabel}"/>
                                <TextBox Grid.Row="10" Grid.Column="1" Text="{Binding WCost, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource SafeInt}}" Style="{StaticResource EditorInput}"/>
                                <TextBlock Grid.Row="10" Grid.Column="2" Text="Enabled" Style="{StaticResource EditorLabel}"/>
                                <CheckBox Grid.Row="10" Grid.Column="3" IsChecked="{Binding WEnabled}" VerticalAlignment="Center"/>

                                <TextBlock Grid.Row="12" Grid.Column="0" Text="Description" Style="{StaticResource EditorLabel}" VerticalAlignment="Top"/>
                                <TextBox Grid.Row="12" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding WDesc, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource EditorInput}" TextWrapping="Wrap" AcceptsReturn="True" Height="60"/>
                            </Grid>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <!-- enemies tab section -->
            <TabItem Header="👾 Enemies" Foreground="{StaticResource Text1}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="350"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Background="{StaticResource Bg2}" CornerRadius="6" Margin="4">
                        <ListView ItemsSource="{Binding Enemies}" SelectedItem="{Binding SelectedEnemy}"
                                  Background="Transparent" BorderThickness="0" Foreground="{StaticResource Text1}">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Name" Width="140">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Name}" Foreground="#E0E0E0" FontSize="12"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Type" Width="70">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding EnemyType}" Foreground="#8892A0" FontSize="11"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="HP" Width="55">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Health}" Foreground="#4CAF50" FontSize="11"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Border>

                    <Border Grid.Column="1" Background="{StaticResource Bg2}" CornerRadius="6" Margin="4" Padding="16">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" Style="{StaticResource EditorLabel}"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding EName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorInput}"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Type" Style="{StaticResource EditorLabel}"/>
                                <ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding EnemyTypes}" SelectedItem="{Binding EType}" FontSize="12"/>
                                <TextBlock Grid.Row="2" Grid.Column="2" Text="Enabled" Style="{StaticResource EditorLabel}"/>
                                <CheckBox Grid.Row="2" Grid.Column="3" IsChecked="{Binding EEnabled}" VerticalAlignment="Center"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Health" Style="{StaticResource EditorLabel}"/>
                                <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding EHealth, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource SafeInt}}" Style="{StaticResource EditorInput}"/>
                                <TextBlock Grid.Row="4" Grid.Column="2" Text="Damage" Style="{StaticResource EditorLabel}"/>
                                <TextBox Grid.Row="4" Grid.Column="3" Text="{Binding EDamage, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource SafeInt}}" Style="{StaticResource EditorInput}"/>

                                <TextBlock Grid.Row="6" Grid.Column="0" Text="Move Speed" Style="{StaticResource EditorLabel}"/>
                                <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding EMoveSpeed, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource SafeDouble}}" Style="{StaticResource EditorInput}"/>
                                <TextBlock Grid.Row="6" Grid.Column="2" Text="XP Reward" Style="{StaticResource EditorLabel}"/>
                                <TextBox Grid.Row="6" Grid.Column="3" Text="{Binding EXpReward, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource SafeInt}}" Style="{StaticResource EditorInput}"/>

                                <TextBlock Grid.Row="8" Grid.Column="0" Text="Spawn %" Style="{StaticResource EditorLabel}"/>
                                <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding ESpawnChance, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource SafeDouble}}" Style="{StaticResource EditorInput}"/>
                                <TextBlock Grid.Row="8" Grid.Column="2" Text="Min Level" Style="{StaticResource EditorLabel}"/>
                                <TextBox Grid.Row="8" Grid.Column="3" Text="{Binding EMinLevel, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource SafeInt}}" Style="{StaticResource EditorInput}"/>

                                <TextBlock Grid.Row="10" Grid.Column="0" Text="Description" Style="{StaticResource EditorLabel}" VerticalAlignment="Top"/>
                                <TextBox Grid.Row="10" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding EDesc, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource EditorInput}" TextWrapping="Wrap" AcceptsReturn="True" Height="60"/>
                            </Grid>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <!-- items tab section -->
            <TabItem Header="🎒 Items" Foreground="{StaticResource Text1}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="350"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Background="{StaticResource Bg2}" CornerRadius="6" Margin="4">
                        <ListView ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem}"
                                  Background="Transparent" BorderThickness="0" Foreground="{StaticResource Text1}">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Name" Width="140">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Name}" Foreground="#E0E0E0" FontSize="12"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Type" Width="80">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding ItemType}" Foreground="#8892A0" FontSize="11"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Rarity" Width="70">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Rarity}" Foreground="#FFD700" FontSize="11"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Border>

                    <Border Grid.Column="1" Background="{StaticResource Bg2}" CornerRadius="6" Margin="4" Padding="16">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" Style="{StaticResource EditorLabel}"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding IName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorInput}"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Item Type" Style="{StaticResource EditorLabel}"/>
                                <ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding ItemTypes}" SelectedItem="{Binding IType}" FontSize="12"/>
                                <TextBlock Grid.Row="2" Grid.Column="2" Text="Rarity" Style="{StaticResource EditorLabel}"/>
                                <ComboBox Grid.Row="2" Grid.Column="3" ItemsSource="{Binding Rarities}" SelectedItem="{Binding IRarity}" FontSize="12"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Value" Style="{StaticResource EditorLabel}"/>
                                <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding IValue, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource SafeInt}}" Style="{StaticResource EditorInput}"/>
                                <TextBlock Grid.Row="4" Grid.Column="2" Text="Drop Rate %" Style="{StaticResource EditorLabel}"/>
                                <TextBox Grid.Row="4" Grid.Column="3" Text="{Binding IDropRate, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource SafeDouble}}" Style="{StaticResource EditorInput}"/>

                                <TextBlock Grid.Row="6" Grid.Column="0" Text="Max Stack" Style="{StaticResource EditorLabel}"/>
                                <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding IMaxStack, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource SafeInt}}" Style="{StaticResource EditorInput}"/>
                                <TextBlock Grid.Row="6" Grid.Column="2" Text="Level Req" Style="{StaticResource EditorLabel}"/>
                                <TextBox Grid.Row="6" Grid.Column="3" Text="{Binding ILevelReq, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource SafeInt}}" Style="{StaticResource EditorInput}"/>

                                <TextBlock Grid.Row="8" Grid.Column="0" Text="Tradeable" Style="{StaticResource EditorLabel}"/>
                                <CheckBox Grid.Row="8" Grid.Column="1" IsChecked="{Binding ITradeable}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="8" Grid.Column="2" Text="Enabled" Style="{StaticResource EditorLabel}"/>
                                <CheckBox Grid.Row="8" Grid.Column="3" IsChecked="{Binding IEnabled}" VerticalAlignment="Center"/>

                                <TextBlock Grid.Row="10" Grid.Column="0" Text="Description" Style="{StaticResource EditorLabel}" VerticalAlignment="Top"/>
                                <TextBox Grid.Row="10" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding IDesc, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource EditorInput}" TextWrapping="Wrap" AcceptsReturn="True" Height="60"/>
                            </Grid>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- status bar section -->
        <Border Grid.Row="2" Background="{StaticResource Bg2}" Padding="12,6"
                BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#F85149"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Fill" Value="#3FB950"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource Text2}" FontSize="11"/>
                </StackPanel>
                <TextBlock Text="gRPC + Entity Framework + MVVM" Foreground="{StaticResource Text2}"
                           FontSize="10" HorizontalAlignment="Right"/>
            </Grid>
        </Border>
    </Grid>
</Window>